/* Glaise brand pack — <Client Name>
   Brand brief: <primary theme: dark|light> · <one-line character>
   Generated by glaise-brand. Overrides --glaise-* tokens; anything not
   listed falls through to tokens.css (the default skin).
   Load LAST: @import "tokens.css"; [theme.css if Tailwind;] @import "brand.css";
   Note: a token set only in :root {} (no light block) applies to BOTH themes —
   to scope a value to one theme, put it in that theme's block.
   AA is checked by glaise-audit (contrast.mjs --brand): it flags any failing pair and
   prints a hue-preserving suggested value to apply here. */
:root {
  /* Accent — the brand color (hover/focus derived) */
  --glaise-primary: #2f6df0;
  --glaise-primary-hover: #5688f5;
  --glaise-primary-focus: #2f6df0;

  /* Neutrals — canvas + surface ladder + hairlines (light re-skin overrides few; full identity overrides all) */
  --glaise-canvas: #07090d;
  --glaise-surface-1: #11141a;

  /* Type — keep Inter (omit to inherit) or swap the family */
  /* --glaise-font-sans: "Geist", -apple-system, system-ui, sans-serif; */

  /* Radii / density — override the scale or a single character if the brand needs it */
  /* --glaise-radius-md: 4px; */
}

/* The opposite theme — derived (hue preserved, surface/ink relationship inverted).
   glaise-audit validates AA over BOTH blocks and suggests a value for any failing pair. */
:root[data-theme="light"] {
  --glaise-primary: #2257c8;
  --glaise-primary-hover: #3568d8;
  --glaise-primary-focus: #2257c8;
  --glaise-canvas: #f3f5f9;
  --glaise-surface-1: #ffffff;
}
